PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/srm_db
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# JWT configuration
ACCESS_TOKEN_SECRET=change_me_access_secret
REFRESH_TOKEN_SECRET=change_me_refresh_secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
JWT_ISSUER=service-repair-api
STAFF_REGISTRATION_SOURCE=staff-portal
STAFF_REGISTRATION_SECRET=change_me_staff_registration_secret

# Optional Redis (not currently used for auth)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_PREFIX=


#Used for email verification links: {APP_URL}/api/v1/users/verify-email
APP_URL=http://localhost:3000
#{FRONTEND_URL}/reset-password?token=
FRONTEND_URL=http://localhost:5173

RESEND_API_KEY=
EMAIL_FROM=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
