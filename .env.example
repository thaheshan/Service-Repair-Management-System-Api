PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/srm_db
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# JWT configuration
ACCESS_TOKEN_SECRET=change_me_access_secret
REFRESH_TOKEN_SECRET=change_me_refresh_secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
JWT_ISSUER=service-repair-api

# Optional Redis (not currently used for auth)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
# Optional; feature-flag keys become {prefix}:ff:tenant:<id> when set
REDIS_PREFIX=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=abcdabcdabcdabcd
SMTP_FROM=your_gmail@gmail.com
APP_URL=http://localhost:3000
