// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  TECHNICIAN
  CUSTOMER
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
}

enum RepairStatus {
  NOT_STARTED
  IN_PROGRESS
  READY_TO_TAKE
  DELIVERED
  PAID
}

enum SubscriptionPlan {
  SINGLE
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_PAYMENT
}

enum PaymentType {
  ADVANCE
  PARTIAL
  FULL
}

enum PaymentStatus {
  PENDING
  OVERDUE
  COMPLETED
  FAILED
}

enum DeviceStatus {
  ACTIVE
  AVAILABLE
  ON_SALE
  SOLD
  IN_SERVICE
  COLLECTED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shops Shop[]
  users User[]
}

model Shop {
  id                    String              @id @default(cuid())
  shopCode              String              @unique
  tenantId              String
  name                  String
  businessRegistration  String?
  address               String?
  city                  String?
  country               String?
  postalCode            String?
  phone                 String?
  email                 String?
  website               String?
  logoUrl               String?
  taxNumber             String?
  brn                   String?
  branches              String?
  repairTypes           String[]
  plan                  String?
  subscriptionPlan      SubscriptionPlan?   @default(SINGLE)
  subscriptionStatus    SubscriptionStatus? @default(SUSPENDED)
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  isActive              Boolean             @default(true)
  acceptsStaffRegistrations Boolean         @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users          User[]
  customers      Customer[]
  devices        Device[]
  repairs        Repair[]
  payments       Payment[]
  partsInventory PartsInventory[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]
  settings       ShopSettings?
  appointments   Appointment[]
  tasks          Task[]
  staffRoles     StaffRole[]
  
  @@index([tenantId])
}

model User {
  id              String   @id @default(cuid())
  tenantId        String
  shopId          String?
  fullName        String
  name            String?
  staffDisplayId  String?
  email           String?  @unique
  phone           String?  @unique
  password        String
  role            UserRole @default(TECHNICIAN)
  specialties     String[] @default([])
  isActive        Boolean  @default(true)
  isEmailVerified Boolean  @default(false)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop                    Shop?                    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  assignedTasks     Task[]   @relation("AssignedTasks")
  createdTasks      Task[]   @relation("CreatedTasks")
  repairs                 Repair[]
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  emailLogs               EmailLog[]
  repairPartsUsed         RepairPartsUsed[]
  appointments            Appointment[] @relation("TechnicianAppointments")
  repairNotes             RepairNote[]
  customerNotes           CustomerNote[]
  poAudits                PurchaseOrderAudit[]

  @@index([tenantId])
  @@index([shopId])
}


model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model RefreshToken {
  id        String    @id
  userId    String
  tenantId  String
  shopId    String?
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([shopId])
}

model Customer {
  id            String       @id @default(cuid())
  tenantId      String
  shopId        String
  name          String
  phone         String?
  email         String?
  address       String?
  customerType  CustomerType @default(INDIVIDUAL)
  loyaltyPoints Int          @default(0)
  tier          String   @default("Bronze")
  tags          String[] @default([])
  preferences   Json?    @default("{\"preferredContact\": \"Phone\", \"notifications\": {\"email\": true, \"sms\": true, \"push\": true}, \"language\": \"English\"}")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop         Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  devices      Device[]
  repairs      Repair[]
  payments     Payment[]
  appointments Appointment[]
  notes        CustomerNote[]

  @@index([tenantId])
  @@index([shopId])
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  userId     String
  text       String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([customerId])
}


model Device {
  id         String   @id @default(cuid())
  tenantId   String
  shopId     String
  customerId String
  brand      String
  model      String
  type       String?
  imei       String?
  serialNo   String?
  price      Int?
  status     DeviceStatus @default(ACTIVE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairs  Repair[]

  @@index([tenantId])
  @@index([shopId])
  @@index([customerId])
  @@unique([shopId, imei])
}

model Repair {
  id                      String       @id @default(cuid())
  tenantId                String
  shopId                  String
  customerId              String
  deviceId                String
  reference               String       @unique
  status                  RepairStatus @default(NOT_STARTED)
  issue                   String?
  diagnosis               String?
  estimatedCost           Int?
  finalCost               Int?
  technicianId            String?
  priority                Priority     @default(MEDIUM)
  estimatedCompletionDate DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  customer        Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  device          Device            @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  shop            Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  technician      User?             @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  photos          Photo[]
  notifications   Notification[]
  payments        Payment[]
  repairPartsUsed RepairPartsUsed[]
  appointment     Appointment?
  notes           RepairNote[]
  timeline        RepairTimelineEvent[]
  tasks             Task[]
  @@index([tenantId])
  @@index([shopId])
  @@index([deviceId])
  @@index([customerId])
  @@index([technicianId])
}

enum Priority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

model RepairNote {
  id        String   @id @default(cuid())
  repairId  String
  userId    String
  text      String
  createdAt DateTime @default(now())

  repair Repair @relation(fields: [repairId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([repairId])
}

model RepairTimelineEvent {
  id          String   @id @default(cuid())
  repairId    String
  type        String   // CREATED, STATUS_CHANGE, NOTE_ADDED, etc.
  description String
  userId      String?
  createdAt   DateTime @default(now())

  repair Repair @relation(fields: [repairId], references: [id], onDelete: Cascade)

  @@index([repairId])
}

model Photo {
  id        String   @id @default(cuid())
  tenantId  String
  repairId  String
  url       String
  stage     String?
  createdAt DateTime @default(now())

  repair Repair @relation(fields: [repairId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([repairId])
}

model Notification {
  id          String    @id @default(cuid())
  tenantId    String
  shopId      String?   // Added for shop-specific in-app alerts
  repairId    String?
  channel     String    @default("IN_APP") // Default to in-app
  to          String?   // Optional for in-app
  title       String?   // For in-app alerts
  message     String
  type        String?   // REPAIR, INVENTORY, etc.
  isRead      Boolean   @default(false)
  isCleared   Boolean   @default(false)
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
  sentAt      DateTime?

  repair Repair? @relation(fields: [repairId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([shopId])
  @@index([repairId])
  @@index([isRead])
  @@index([isCleared])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String
  email     String
  type      String
  status    String
  attempts  Int      @default(1)
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Payment {
  id                   String        @id @default(uuid())
  tenantId             String
  shopId               String
  repairId             String?
  customerId           String?
  paymentMethod        PaymentMethod
  paymentType          PaymentType
  amount               Decimal       @db.Decimal(10, 2)
  transactionReference String?       @unique
  status               PaymentStatus @default(PENDING)
  paymentDate          DateTime      @default(now())
  userId               String?
  notes                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repair   Repair?   @relation(fields: [repairId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([shopId])
  @@index([repairId])
  @@index([customerId])
  @@index([paymentDate])
}

model PartsInventory {
  id                String   @id @default(cuid())
  tenantId          String
  shopId            String
  partName          String
  partNumber        String?
  category          String?
  compatibleBrands  String[]
  compatibleModels  String[]
  supplierName      String?
  quantityInStock   Int      @default(0)
  minimumStockLevel Int      @default(0)
  unitCost          Float
  sellingPrice      Float
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  shop            Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairPartsUsed RepairPartsUsed[]
  supplierId      String?
  supplier        Supplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  poItems         PurchaseOrderItem[]

  @@index([tenantId])
  @@index([shopId])
  @@index([category])
  @@index([supplierId])
}

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  shopId      String
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  website     String?
  category    String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop            Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  purchaseOrders  PurchaseOrder[]
  inventoryItems  PartsInventory[]

  @@index([tenantId])
  @@index([shopId])
}

model PurchaseOrder {
  id               String   @id @default(cuid())
  tenantId         String
  shopId           String
  supplierId       String
  orderNumber      String   @unique
  status           String   @default("DRAFT") // DRAFT, SENT, RECEIVED, CANCELLED
  totalAmount      Decimal  @db.Decimal(10, 2)
  notes            String?
  expectedDelivery DateTime?
  receivedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  shop            Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier        Supplier          @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items           PurchaseOrderItem[]
  auditLogs       PurchaseOrderAudit[]

  @@index([tenantId])
  @@index([shopId])
  @@index([supplierId])
}

model PurchaseOrderAudit {
  id              String   @id @default(cuid())
  tenantId        String
  shopId          String
  purchaseOrderId String
  adminId         String
  oldStatus       String?
  newStatus       String
  notes           String?
  createdAt       DateTime @default(now())

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  admin           User          @relation(fields: [adminId], references: [id])

  @@index([purchaseOrderId])
  @@index([shopId])
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  partId          String?
  partName        String
  sku             String?
  quantity        Int
  unitCost        Decimal  @db.Decimal(10, 2)
  totalCost       Decimal  @db.Decimal(10, 2)

  purchaseOrder   PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  part            PartsInventory? @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@index([partId])
}

model RepairPartsUsed {
  id            String   @id @default(cuid())
  repairId      String
  partId        String
  quantityUsed  Int
  unitPrice     Float
  totalPrice    Float
  addedByUserId String
  addedAt       DateTime @default(now())

  repair   Repair         @relation(fields: [repairId], references: [id], onDelete: Cascade)
  part     PartsInventory @relation(fields: [partId], references: [id], onDelete: Restrict)
  addedBy  User           @relation(fields: [addedByUserId], references: [id])

  @@index([repairId])
  @@index([partId])
}

model ShopSettings {
  id                      String   @id @default(uuid())
  tenantId                String   @unique
  businessHours           Json?
  notificationPreferences Json?
  emailSettings           Json?
  smsSettings             Json?
  invoiceSettings         Json?
  defaultWarrantyDays     Int      @default(30)
  taxRate                 Decimal  @default(0.00) @db.Decimal(5, 2)
  currency                String   @default("LKR")
  timezone                String?
  language                String?  @default("en")
  dateFormat              String?
  appearance              Json?
  securityRules           Json?
  featureFlags            Json?
  updatedAt               DateTime @updatedAt

  shop Shop @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model RegistrationRequest {
  id            String   @id @default(cuid())
  shopName      String
  ownerEmail    String
  ownerName     String
  fullData      Json
  status        String   @default("PENDING")
  approvalToken String   @unique
  paymentId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([approvalToken])
  @@index([ownerEmail])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  adminId   String
  flagName  String
  oldVal    Boolean
  newVal    Boolean
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([adminId])
}

model Appointment {
  id           String   @id @default(cuid())
  tenantId     String
  shopId       String
  customerId   String?
  technicianId String?
  repairId     String?  @unique
  scheduledAt  DateTime
  duration     Int      @default(60)
  status       String   @default("SCHEDULED")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop       Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  technician User?     @relation("TechnicianAppointments", fields: [technicianId], references: [id], onDelete: SetNull)
  repair     Repair?   @relation(fields: [repairId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([shopId])
  @@index([scheduledAt])
}

model Task {
  id                String   @id @default(cuid())
  tenantId          String
  shopId            String
  title             String
  description       String?
  status            String   @default("pending") // pending, in_progress, completed, on_hold
  priority          String   @default("medium") // low, medium, high, urgent
  assignedToUserId  String?
  createdByUserId   String
  dueDate           DateTime?
  repairId          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  assignedTo        User?    @relation("AssignedTasks", fields: [assignedToUserId], references: [id])
  createdBy         User     @relation("CreatedTasks", fields: [createdByUserId], references: [id])
  repair            Repair?  @relation(fields: [repairId], references: [id])
  
  @@index([tenantId])
  @@index([shopId])
  @@index([assignedToUserId])
  @@index([status])
}

model StaffRole {
  id          String   @id @default(cuid())
  tenantId    String
  shopId      String
  name        String
  color       String   @default("#4F46E5")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
  @@index([shopId])
}