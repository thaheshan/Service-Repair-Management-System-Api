// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  TECHNICIAN
  CUSTOMER
}

enum RepairStatus {
  NOT_STARTED
  IN_PROGRESS
  READY_TO_TAKE
  DELIVERED
}

enum RepairPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SubscriptionPlan {
  SINGLE
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_PAYMENT
}

enum PaymentType {
  ADVANCE
  PARTIAL
  FULL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shops Shop[]
  users User[]
}

model Shop {
  id                    String              @id @default(cuid())
  shopCode              String              @unique
  tenantId              String
  name                  String
  businessRegistration  String?
  address               String?
  city                  String?
  country               String?
  postalCode            String?
  phone                 String?
  email                 String?
  website               String?
  logoUrl               String?
  taxNumber             String?
  brn                   String?
  branches              String?
  repairTypes           String[]
  plan                  String?
  subscriptionPlan      SubscriptionPlan?   @default(SINGLE)
  subscriptionStatus    SubscriptionStatus? @default(SUSPENDED)
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  isActive              Boolean             @default(true)
  acceptsStaffRegistrations Boolean         @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users          User[]
  customers      Customer[]
  devices        Device[]
  repairs        Repair[]
  payments       Payment[]
  partsInventory PartsInventory[]
  settings       ShopSettings?

  @@index([tenantId])
}

model User {
  id              String   @id @default(cuid())
  tenantId        String
  shopId          String?
  fullName        String
  name            String?
  staffDisplayId  String?
  email           String?  @unique
  phone           String?  @unique
  password        String
  role            UserRole @default(TECHNICIAN)
  isActive        Boolean  @default(true)
  isEmailVerified Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop                    Shop?                    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  repairs                 Repair[]
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  emailLogs               EmailLog[]
  repairPartsUsed         RepairPartsUsed[]

  @@index([tenantId])
  @@index([shopId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model RefreshToken {
  id        String    @id
  userId    String
  tenantId  String
  shopId    String?
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([shopId])
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  shopId    String
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  devices  Device[]
  repairs  Repair[]
  payments Payment[]

  @@index([tenantId])
  @@index([shopId])
}

model Device {
  id         String   @id @default(cuid())
  tenantId   String
  shopId     String
  customerId String
  brand      String
  model      String
  imei       String?
  serialNo   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairs  Repair[]

  @@index([tenantId])
  @@index([shopId])
  @@index([customerId])
  @@unique([shopId, imei])
}

model Repair {
  id                      String          @id @default(cuid())
  tenantId                String
  shopId                  String
  customerId              String
  deviceId                String
  reference               String          @unique
  status                  RepairStatus    @default(NOT_STARTED)
  priority                RepairPriority  @default(MEDIUM)
  issue                   String?
  diagnosis               String?
  estimatedCost           Int?
  finalCost               Int?
  estimatedCompletionDate DateTime?
  technicianId            String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  customer        Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  device          Device            @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  shop            Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  technician      User?             @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  photos          Photo[]
  notifications   Notification[]
  payments        Payment[]
  repairPartsUsed RepairPartsUsed[]

  @@index([tenantId])
  @@index([shopId])
  @@index([deviceId])
  @@index([customerId])
  @@index([technicianId])
}

model Photo {
  id        String   @id @default(cuid())
  tenantId  String
  repairId  String
  url       String
  stage     String?
  createdAt DateTime @default(now())

  repair Repair @relation(fields: [repairId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([repairId])
}

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  repairId  String?
  channel   String
  to        String
  message   String
  status    String    @default("PENDING")
  createdAt DateTime  @default(now())
  sentAt    DateTime?

  repair Repair? @relation(fields: [repairId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([repairId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String
  email     String
  type      String
  status    String
  attempts  Int      @default(1)
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Payment {
  id                   String        @id @default(uuid())
  tenantId             String
  repairId             String?
  customerId           String?
  paymentMethod        PaymentMethod
  paymentType          PaymentType
  amount               Decimal       @db.Decimal(10, 2)
  transactionReference String?       @unique
  status               PaymentStatus @default(PENDING)
  paymentDate          DateTime      @default(now())
  userId               String?
  notes                String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  shop     Shop      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  repair   Repair?   @relation(fields: [repairId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([repairId])
  @@index([customerId])
  @@index([paymentDate])
}

model PartsInventory {
  id                String   @id @default(cuid())
  tenantId          String
  shopId            String
  partName          String
  partNumber        String?
  category          String?
  compatibleBrands  String[]
  compatibleModels  String[]
  supplierName      String?
  quantityInStock   Int      @default(0)
  minimumStockLevel Int      @default(0)
  unitCost          Float
  sellingPrice      Float
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  shop            Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairPartsUsed RepairPartsUsed[]

  @@index([tenantId])
  @@index([shopId])
  @@index([category])
}

model RepairPartsUsed {
  id            String   @id @default(cuid())
  repairId      String
  partId        String
  quantityUsed  Int
  unitPrice     Float
  totalPrice    Float
  addedByUserId String
  addedAt       DateTime @default(now())

  repair   Repair         @relation(fields: [repairId], references: [id], onDelete: Cascade)
  part     PartsInventory @relation(fields: [partId], references: [id], onDelete: Restrict)
  addedBy  User           @relation(fields: [addedByUserId], references: [id])

  @@index([repairId])
  @@index([partId])
}

model ShopSettings {
  id                      String   @id @default(uuid())
  tenantId                String   @unique
  businessHours           Json?
  notificationPreferences Json?
  emailSettings           Json?
  smsSettings             Json?
  invoiceSettings         Json?
  defaultWarrantyDays     Int      @default(30)
  taxRate                 Decimal  @default(0.00) @db.Decimal(5, 2)
  currency                String   @default("LKR")
  timezone                String?
  dateFormat              String?
  featureFlags            Json?
  updatedAt               DateTime @updatedAt

  shop Shop @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model RegistrationRequest {
  id            String   @id @default(cuid())
  shopName      String
  ownerEmail    String
  ownerName     String
  fullData      Json
  status        String   @default("PENDING")
  approvalToken String   @unique
  paymentId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([approvalToken])
  @@index([ownerEmail])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  adminId   String
  flagName  String
  oldVal    Boolean
  newVal    Boolean
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([adminId])
}